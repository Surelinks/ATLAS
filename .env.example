# LLM Provider Configuration
# Options: openai, grok, ollama, local
LLM_PROVIDER=ollama

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Grok Configuration (if using grok provider - FREE tier available)
GROK_API_KEY=your_grok_api_key_here

# Ollama Configuration (if using ollama provider - FULLY FREE local models)
OLLAMA_BASE_URL=http://localhost:11434

# Application Configuration
APP_NAME=Atlas AI
APP_VERSION=1.0.0
ENVIRONMENT=development

# Database Configuration (if using PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/atlas_ai

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Logging
LOG_LEVEL=INFO

# Security (generate a secure random string for production)
SECRET_KEY=your-secret-key-here-change-in-production
