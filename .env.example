# LLM Provider Configuration
# Options: openai, groq, ollama, local
LLM_PROVIDER=groq

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Groq Configuration (if using groq provider - FREE tier with high limits!)
# Models: llama3-70b, mixtral-8x7b, gemma-7b (all free)
GROQ_API_KEY=your_groq_api_key_here

# Ollama Configuration (if using ollama provider - FULLY FREE local models)
OLLAMA_BASE_URL=http://localhost:11434

# Application Configuration
APP_NAME=Atlas AI
APP_VERSION=1.0.0
ENVIRONMENT=development

# Database Configuration (if using PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/atlas_ai

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Logging
LOG_LEVEL=INFO

# Security (generate a secure random string for production)
SECRET_KEY=your-secret-key-here-change-in-production
